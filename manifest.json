{
    "manifest_version": 3,
    "name": "BlurryTweet",
    "version": "1.0.1",
    "description": "트위터 타임라인에서 프로필 블러 처리하기",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "icons": {
        "16": "icons/twitter128.png",
        "32": "icons/twitter128.png",
        "48": "icons/twitter128.png",
        "128": "icons/twitter128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/twitter128.png",
            "32": "icons/twitter128.png",
            "48": "icons/twitter128.png",
            "128": "icons/twitter128.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://x.com/*",
                "https://twitter.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ]
}